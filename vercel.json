{
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/login/?$",
      "dest": "/login.html"
    },
    {
      "src": "^/corretor/?$",
      "dest": "/apps/crm-corretor/index.html"
    },
    {
      "src": "^/admin/?$",
      "dest": "/apps/crm-admin/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/site/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 3 * * *"
    }
  ]
}