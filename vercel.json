{
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/corretor",
      "destination": "/apps/crm-corretor/index.html"
    },
    {
      "source": "/admin",
      "destination": "/apps/crm-admin/index.html"
    },
    {
      "source": "/:slug",
      "destination": "/site/index.html"
    }
  ]
}